# FLY77STAR AI News Digest - Environment Variables Template
# Copy this file to .env and fill in with actual values
# .env is gitignored - never commit this file

# === Google Drive API Settings ===
# Obtained from Google Cloud Console
# https://console.cloud.google.com/
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CREDENTIALS_PATH=./google-credentials.json

# === Gmail Settings ===
# Gmail account for sending notifications
GMAIL_USER=fly77star.official@gmail.com

# Gmail App Password (16 characters with spaces)
# Generated at: https://myaccount.google.com/apppasswords
# Format: xxxx xxxx xxxx xxxx (include spaces)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# === Recipient Email ===
# Email address where YU receives the AI News Digest notifications
YU_EMAIL=fly77star.official@gmail.com

# === Website Configuration ===
# Netlify Website ID for AI News Digest
NETLIFY_SITE_ID=e6203434-2921-4ab8-b614-c783fcf47081
NETLIFY_SITE_NAME=ai-news-digest

# === Logging ===
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# === Node Environment ===
NODE_ENV=production

# === RSS Feeds ===
# (Configured in netlify/functions/ai-news-sync.js)
# - AI: TechCrunch AI feed
# - K-pop: SBS K-pop news
# - US: Reuters business news
# - Japan: NHK news
# - YouTube: YouTube channel feed

# === Cron Schedule ===
# Every 3 days at 09:00 UTC
# Configured in netlify.toml: "0 9 */3 * *"
