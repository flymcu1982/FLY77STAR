# Daily Reminder メール送信設定
# このファイルを .env にコピーして、実際の値に置き換えてください
# .env は Git に含めない（.gitignore に追加済み）

# Gmail アカウント設定
GMAIL_ADDRESS=fly77star.official@gmail.com

# Gmail App Password
# 取得方法:
# 1. https://myaccount.google.com にログイン
# 2. Security → 2-Step Verification を有効化
# 3. App passwords を生成（16文字のパスワード）
# 例: xxxx xxxx xxxx xxxx （スペース含める）
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# YU メールアドレス（受信者）
YU_EMAIL=fly77star.official@gmail.com

# チェックシートベース URL
BASE_URL=https://github.com/flymcu1982/FLY77STAR/tree/claude/fly77star-obsidian-structure-a010jj/Edit

# タイムゾーン
TZ=Asia/Tokyo

# ログレベル（オプション）
# DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
