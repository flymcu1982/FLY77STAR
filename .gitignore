.DS_Store
*.log
*.tmp
*.cache

# Local exports can be large. Track final deliverables only when intentional.
Exports/*.mp4
Projects/*/Export/*.mp4

# Netlify site: keep teaser-size assets only in git-managed copy.
Web/netlify_site/assets/*.mp4
!Web/netlify_site/assets/*_teaser.mp4

# OS/editor noise
.vscode/
.idea/

# Node.js / npm
node_modules/
package-lock.json
npm-debug.log

# Environment variables (Git excluded)
.env
.env.local
.env.*.local
